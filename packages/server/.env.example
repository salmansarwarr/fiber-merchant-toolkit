# Fiber Merchant Toolkit -- environment variables
# Copy to .env and fill in real values. Never commit .env.

# JSON-RPC endpoint of the local fnn daemon (NOT the CKB layer-1 RPC).
# See docs/rpc-samples.md for the two-node local testnet setup used in Phase 0.
FNN_RPC_URL=http://127.0.0.1:8227

# Currency enum fnn expects on new_invoice: Fibb (mainnet) / Fibt (testnet) / Fibd (devnet)
FNN_CURRENCY=Fibt

# RUSD UDT type script (testnet values)
RUSD_CODE_HASH=0x1142755a044bf2ee358cba9f2da187ce928c91cd4dc8692ded0337efa677d21a
RUSD_HASH_TYPE=type
RUSD_ARGS=0x878fcc6f1f08d48e87bb1c3b3d5083f23f8a39c5d5c764f253b55b998526439b

# Ed25519 private key used to sign payment receipts (Phase 4). Never log or commit.
RECEIPT_SIGNING_PRIVATE_KEY=

# Local SQLite ledger pat
LEDGER_DB_PATH=/home/salman/Documents/fiber-merchant-toolkit/data/ledger.sqlite

# Express server port
PORT=3000